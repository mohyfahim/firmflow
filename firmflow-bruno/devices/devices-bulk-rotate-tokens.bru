meta {
  name: devices-bulk-rotate-tokens
  type: http
  seq: 21
}

post {
  url: {{url}}/api/v1/projects/{{project_id}}/devices/bulk
  body: json
  auth: inherit
}

body:json {
  {
    "action": "rotate_tokens",
    "apply_to_filter": false,
    "filter": {},
    "device_ids": [
      "{{device_id}}"
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
