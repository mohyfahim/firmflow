meta {
  name: device-groups-members-remove
  type: http
  seq: 18
}

post {
  url: {{url}}/api/v1/projects/{{project_id}}/device-groups/{{group_id}}/members/remove
  body: json
  auth: inherit
}

body:json {
  {
    "device_ids": [
      "{{device_id}}"
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
