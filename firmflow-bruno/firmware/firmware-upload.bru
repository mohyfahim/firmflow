meta {
  name: firmware-upload
  type: http
  seq: 4
}

post {
  url: {{url}}/api/v1/projects/{{project_id}}/firmwares
  body: multipartForm
  auth: inherit
}

body:multipartForm {
  file: @file(/path/to/your/firmware.bin)
  version: 1.0.0
  changelog: Initial release
  device_type_ids: ["{{device_type_id}}"]
}

settings {
  encodeUrl: true
  timeout: 0
}
